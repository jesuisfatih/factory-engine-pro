# Test/staging/prod databases are managed services. Do not install Postgres on the API server.
# Copy the correct remote env value from the target server and keep sslmode=require for Vultr.
DATABASE_URL="postgresql://USER:PASSWORD@VULTR_MANAGED_POSTGRES_HOST:16751/factory_engine_pro_test?sslmode=require&schema=public"
REDIS_URL="rediss://USER:PASSWORD@VULTR_MANAGED_REDIS_HOST:16752"
JWT_ACCESS_SECRET="replace-with-32-byte-random-secret"
JWT_REFRESH_SECRET="replace-with-32-byte-random-secret"
CONFIG_ENCRYPTION_KEY="replace-with-32-byte-base64-or-hex-key"
BOOTSTRAP_TOKEN="local-bootstrap-token"
ADMIN_APP_URL="http://127.0.0.1:5189"
ACCOUNTS_APP_URL="http://127.0.0.1:5187"
PERSON_APP_URL="http://127.0.0.1:5188"
VITE_API_URL="http://127.0.0.1:4120/api/v1"
VITE_TENANT_ID="ten_remote_test"

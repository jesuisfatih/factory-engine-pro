{
  "name": "factory-engine-pro",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:backend": "pnpm --filter @factory-engine-pro/backend dev",
    "dev:admin": "pnpm --filter @factory-engine-pro/admin dev",
    "dev:person": "pnpm --filter @factory-engine-pro/person dev",
    "dev:accounts": "pnpm --filter @factory-engine-pro/accounts dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "evidence:mail-rollout": "node scripts/mail-rollout-proof.mjs",
    "evidence:resend-webhook": "node scripts/resend-webhook-proof.mjs",
    "evidence:mail-webhook-readiness": "node scripts/mail-webhook-readiness-proof.mjs",
    "evidence:mail-signoff": "node scripts/mail-rollout-signoff.mjs",
    "evidence:person-staff-copy": "node scripts/person-staff-copy-proof.mjs",
    "evidence:person-uix": "node scripts/person-uix-proof.mjs",
    "db:generate": "pnpm --filter @factory-engine-pro/backend prisma:generate",
    "db:migrate": "pnpm --filter @factory-engine-pro/backend prisma:migrate",
    "db:deploy": "pnpm --filter @factory-engine-pro/backend prisma:deploy"
  },
  "devDependencies": {
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  }
}

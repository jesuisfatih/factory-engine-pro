generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  suspended
  archived
}

enum PrincipalType {
  member
  customer_user
  sub_user
}

enum PrincipalStatus {
  invited
  active
  disabled
  archived
}

enum AuthTokenKind {
  refresh
  access_revocation
  password_reset
  invitation
}

enum MailDeliveryStatus {
  queued
  queued_disabled
  sending
  sent
  failed
  skipped
}

model Tenant {
  id        String       @id
  name      String
  slug      String       @unique
  status    TenantStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  config                  TenantConfig?
  members                 Member[]
  memberRoles             MemberRole[]
  memberRoleAssignments   MemberRoleAssignment[]
  customers               Customer[]
  customerUsers           CustomerUser[]
  subUsers                SubUser[]
  customerRoles           CustomerRole[]
  customerUserRoleAssignments CustomerUserRoleAssignment[]
  subUserRoleAssignments  SubUserRoleAssignment[]
  authTokens              AuthToken[]
  authAuditLogs           AuthAuditLog[]
  catalogProducts         CatalogProduct[]
  catalogVariants         CatalogVariant[]
  commerceOrders          CommerceOrder[]
  commercePickupOrders    CommercePickupOrder[]
  commerceActivityLogs    CommerceActivityLog[]
  customerInsights        CustomerInsight[]
  customerLists           CustomerList[]
  customerListItems       CustomerListItem[]
  customerAssignments     CustomerAssignment[]
  customerAssignmentAudits CustomerAssignmentAudit[]
  pricingRules            PricingRule[]
  segments                Segment[]
  segmentOwnerships       SegmentOwnership[]
  segmentCustomerMemberships SegmentCustomerMembership[]
  shopifyCustomerSegments ShopifyCustomerSegment[]
  shopifyCustomerSegmentMembers ShopifyCustomerSegmentMember[]
  segmentCustomerAssignments SegmentCustomerAssignment[]
  serviceRequests         ServiceRequest[]
  serviceRequestComments  ServiceRequestComment[]
  b2bAccessRequests       B2BAccessRequest[]
  b2bAccessRequestFiles   B2BAccessRequestFile[]
  mailDeliveries          MailDelivery[]
  emailTemplates          EmailTemplate[]
  emailTemplateVersions   EmailTemplateVersion[]
  mailContacts            MailContact[]
  mailAudiences           MailAudience[]
  mailFlows               MailFlow[]
  mailMarketingEvents     MailMarketingEvent[]
  mailMarketingSettings   MailMarketingSetting?
  aircallUsers            AircallUser[]
  aircallMemberMaps       AircallMemberMap[]
  aircallNumbers          AircallNumber[]
  aircallWebhookConfig    AircallWebhookConfig?
  aircallWebhookInbox     AircallWebhookInbox[]
  aircallCallEvents       AircallCallEvent[]
  calls                   Call[]
  callEvents              CallEvent[]
  aircallSyncStates       AircallSyncState[]
  shopifySyncStates       ShopifySyncState[]
  syncLogs                SyncLog[]
  workflowRules           WorkflowRule[]
  workflowRuleExecutions  WorkflowRuleExecution[]
  workflowRuleCooldowns   WorkflowRuleCooldown[]
  workflowRuleVersions    WorkflowRuleVersion[]
  workflowRuleBackfillReports WorkflowRuleBackfillReport[]
  taskParticipants        TaskParticipant[]
  personDailyCallOrders   PersonDailyCallOrder[]

  @@map("tenants")
}

model TenantConfig {
  id                         String   @id
  tenantId                   String   @unique @map("tenant_id")
  workspaceName              String?  @map("workspace_name")
  brandBadge                 String?  @map("brand_badge")
  brandLogo                  String?  @map("brand_logo")
  urgencyScoringConfig       Json     @default("{}") @map("urgency_scoring_config")
  shopifyDomain              String?  @map("shopify_domain")
  shopifyAdminTokenEncrypted String?  @map("shopify_admin_token_encrypted")
  shopifyApiKeyEncrypted     String?  @map("shopify_api_key_encrypted")
  shopifyApiSecretEncrypted  String?  @map("shopify_api_secret_encrypted")
  webhookHmacKeyEncrypted    String?  @map("webhook_hmac_key_encrypted")
  aircallApiIdEncrypted      String?  @map("aircall_api_id_encrypted")
  aircallApiTokenEncrypted   String?  @map("aircall_api_token_encrypted")
  aircallWebhookSecretEncrypted String? @map("aircall_webhook_secret_encrypted")
  anthropicApiKeyEncrypted   String?  @map("anthropic_api_key_encrypted")
  resendApiKeyEncrypted      String?  @map("resend_api_key_encrypted")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

model Member {
  id                  String          @id
  tenantId            String          @map("tenant_id")
  email               String
  firstName           String          @map("first_name")
  lastName            String          @map("last_name")
  phone               String?
  passwordHash        String?         @map("password_hash")
  status              PrincipalStatus @default(invited)
  lastLoginAt         DateTime?       @map("last_login_at")
  invitationAcceptedAt DateTime?      @map("invitation_accepted_at")
  aircallUserId       String?         @map("aircall_user_id")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleAssignments MemberRoleAssignment[]
  segmentOwnerships SegmentOwnership[]
  customerAssignments CustomerAssignment[] @relation("CustomerAssignmentMember")
  approvedCustomerAssignments CustomerAssignment[] @relation("CustomerAssignmentApprover")
  previousCustomerAssignmentAudits CustomerAssignmentAudit[] @relation("CustomerAssignmentAuditPreviousMember")
  newCustomerAssignmentAudits CustomerAssignmentAudit[] @relation("CustomerAssignmentAuditNewMember")
  actorCustomerAssignmentAudits CustomerAssignmentAudit[] @relation("CustomerAssignmentAuditActor")
  assignedServiceRequests ServiceRequest[]
  taskParticipants TaskParticipant[]
  aircallMemberMaps AircallMemberMap[]
  workflowRuleVersions WorkflowRuleVersion[]
  workflowRuleBackfillReports WorkflowRuleBackfillReport[]
  dailyCallOrders PersonDailyCallOrder[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, aircallUserId])
  @@map("members")
}

model MemberRole {
  id          String   @id
  tenantId    String   @map("tenant_id")
  slug        String
  name        String
  description String?
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments MemberRoleAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("member_roles")
}

model MemberRoleAssignment {
  id        String   @id
  tenantId  String   @map("tenant_id")
  memberId  String   @map("member_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   MemberRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, memberId, roleId])
  @@index([tenantId, memberId])
  @@index([tenantId, roleId])
  @@map("member_role_assignments")
}

model Customer {
  id                String   @id
  tenantId          String   @map("tenant_id")
  shopifyCustomerId String?  @map("shopify_customer_id")
  companyName       String   @map("company_name")
  legalName         String?  @map("legal_name")
  firstName         String?  @map("first_name")
  lastName          String?  @map("last_name")
  taxId             String?  @map("tax_id")
  email             String?
  phone             String?
  billingAddress    Json?    @map("billing_address")
  shippingAddress   Json?    @map("shipping_address")
  tags              String[] @default([])
  note              String?
  totalSpent        Decimal  @default(0) @map("total_spent") @db.Decimal(12, 2)
  ordersCount       Int      @default(0) @map("orders_count")
  lastOrderAt       DateTime? @map("last_order_at")
  averageOrderValue Decimal  @default(0) @map("average_order_value") @db.Decimal(12, 2)
  rawData           Json?    @map("raw_data")
  syncedAt          DateTime? @map("synced_at")
  status            String   @default("active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerUsers CustomerUser[]
  subUsers      SubUser[]
  orders        CommerceOrder[]
  pickupOrders  CommercePickupOrder[]
  activityLogs  CommerceActivityLog[]
  insight       CustomerInsight?
  listItems     CustomerListItem[]
  assignments   CustomerAssignment[]
  assignmentAudits CustomerAssignmentAudit[]
  pricingRules  PricingRule[]
  segmentMemberships SegmentCustomerMembership[]
  segmentAssignments SegmentCustomerAssignment[]
  serviceRequests ServiceRequest[]
  workflowRuleCooldowns WorkflowRuleCooldown[]
  dailyCallOrders PersonDailyCallOrder[]

  @@unique([tenantId, shopifyCustomerId])
  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([tenantId, lastOrderAt])
  @@map("customers")
}

model CustomerAssignment {
  id                 String   @id
  tenantId           String   @map("tenant_id")
  customerId         String   @map("customer_id")
  axis               String
  memberId           String   @map("member_id")
  isPrimary          Boolean  @default(true) @map("is_primary")
  source             String   @default("admin_transfer")
  reason             String?
  approvedByMemberId String?  @map("approved_by_member_id")
  approvedAt         DateTime? @map("approved_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  member     Member   @relation("CustomerAssignmentMember", fields: [memberId], references: [id], onDelete: Restrict)
  approvedBy Member?  @relation("CustomerAssignmentApprover", fields: [approvedByMemberId], references: [id], onDelete: SetNull)

  @@unique([tenantId, customerId, axis])
  @@index([tenantId, memberId, axis])
  @@index([tenantId, axis])
  @@map("customer_assignments")
}

model CustomerAssignmentAudit {
  id               String   @id
  tenantId         String   @map("tenant_id")
  customerId       String   @map("customer_id")
  axis             String
  action           String
  previousMemberId String?  @map("previous_member_id")
  newMemberId      String?  @map("new_member_id")
  actorMemberId    String?  @map("actor_member_id")
  source           String   @default("admin_transfer")
  reason           String?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  previousMember Member?  @relation("CustomerAssignmentAuditPreviousMember", fields: [previousMemberId], references: [id], onDelete: SetNull)
  newMember      Member?  @relation("CustomerAssignmentAuditNewMember", fields: [newMemberId], references: [id], onDelete: SetNull)
  actorMember    Member?  @relation("CustomerAssignmentAuditActor", fields: [actorMemberId], references: [id], onDelete: SetNull)

  @@index([tenantId, customerId, axis])
  @@index([tenantId, action])
  @@index([tenantId, createdAt])
  @@map("customer_assignment_audits")
}

model CustomerUser {
  id            String          @id
  tenantId      String          @map("tenant_id")
  customerId    String          @map("customer_id")
  email         String
  firstName     String          @map("first_name")
  lastName      String          @map("last_name")
  phone         String?
  passwordHash  String?         @map("password_hash")
  status        PrincipalStatus @default(invited)
  spendingLimitCents Int?       @map("spending_limit_cents")
  spendingUsedCents  Int        @default(0) @map("spending_used_cents")
  lastLoginAt   DateTime?       @map("last_login_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant          Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subUsers        SubUser[]
  roleAssignments CustomerUserRoleAssignment[]
  orders          CommerceOrder[]
  pickupOrders    CommercePickupOrder[]
  pricingRules    PricingRule[]
  serviceRequests ServiceRequest[]

  @@unique([tenantId, email])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@map("customer_users")
}

model SubUser {
  id            String          @id
  tenantId      String          @map("tenant_id")
  customerId    String          @map("customer_id")
  parentUserId  String          @map("parent_user_id")
  email         String
  firstName     String          @map("first_name")
  lastName      String          @map("last_name")
  phone         String?
  passwordHash  String?         @map("password_hash")
  status        PrincipalStatus @default(invited)
  spendingLimitCents Int?       @map("spending_limit_cents")
  spendingUsedCents  Int        @default(0) @map("spending_used_cents")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  parentUser      CustomerUser            @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  roleAssignments SubUserRoleAssignment[]

  @@unique([tenantId, email])
  @@index([tenantId, customerId])
  @@index([tenantId, parentUserId])
  @@index([tenantId, status])
  @@map("sub_users")
}

model CustomerRole {
  id          String   @id
  tenantId    String   @map("tenant_id")
  slug        String
  name        String
  description String?
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant                  Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerUserAssignments CustomerUserRoleAssignment[]
  subUserAssignments      SubUserRoleAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("customer_roles")
}

model CustomerUserRoleAssignment {
  id             String   @id
  tenantId       String   @map("tenant_id")
  customerUserId String   @map("customer_user_id")
  roleId         String   @map("role_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerUser CustomerUser @relation(fields: [customerUserId], references: [id], onDelete: Cascade)
  role         CustomerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerUserId, roleId])
  @@index([tenantId, customerUserId])
  @@index([tenantId, roleId])
  @@map("customer_user_role_assignments")
}

model SubUserRoleAssignment {
  id        String   @id
  tenantId  String   @map("tenant_id")
  subUserId String   @map("sub_user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subUser SubUser      @relation(fields: [subUserId], references: [id], onDelete: Cascade)
  role    CustomerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, subUserId, roleId])
  @@index([tenantId, subUserId])
  @@index([tenantId, roleId])
  @@map("sub_user_role_assignments")
}

model AuthToken {
  id            String        @id
  tenantId      String        @map("tenant_id")
  kind          AuthTokenKind
  principalType PrincipalType @map("principal_type")
  principalId   String        @map("principal_id")
  tokenHash     String        @unique @map("token_hash")
  expiresAt     DateTime      @map("expires_at")
  usedAt        DateTime?     @map("used_at")
  revokedAt     DateTime?     @map("revoked_at")
  metadata      Json          @default("{}")
  createdById   String?       @map("created_by_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kind, principalType, principalId])
  @@index([tenantId, expiresAt])
  @@map("auth_tokens")
}

model AuthAuditLog {
  id            String         @id
  tenantId      String         @map("tenant_id")
  principalType PrincipalType? @map("principal_type")
  principalId   String?        @map("principal_id")
  email         String?
  action        String
  requestId     String?        @map("request_id")
  ipAddress     String?        @map("ip_address")
  userAgent     String?        @map("user_agent")
  success       Boolean
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, action, createdAt])
  @@index([tenantId, email])
  @@map("auth_audit_logs")
}

model CatalogProduct {
  id               String   @id
  tenantId         String   @map("tenant_id")
  shopifyProductId String   @map("shopify_product_id")
  title            String
  handle           String?
  vendor           String?
  productType      String?  @map("product_type")
  tags             String[] @default([])
  status           String   @default("active")
  images           Json?
  collections      Json?
  rawData          Json?    @map("raw_data")
  syncedAt         DateTime @default(now()) @map("synced_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants CatalogVariant[]

  @@unique([tenantId, shopifyProductId])
  @@index([tenantId, handle])
  @@index([tenantId, status])
  @@map("catalog_products")
}

model CatalogVariant {
  id                String   @id
  tenantId          String   @map("tenant_id")
  productId         String   @map("product_id")
  shopifyVariantId  String   @map("shopify_variant_id")
  sku               String?
  title             String
  price             Decimal  @default(0) @db.Decimal(12, 2)
  compareAtPrice    Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  inventoryQuantity Int?     @map("inventory_quantity")
  inventoryPolicy   String?  @map("inventory_policy")
  availableForSale  Boolean  @default(true) @map("available_for_sale")
  position          Int      @default(0)
  rawData           Json?    @map("raw_data")
  syncedAt          DateTime @default(now()) @map("synced_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, shopifyVariantId])
  @@index([tenantId, productId])
  @@index([tenantId, sku])
  @@map("catalog_variants")
}

model CommerceOrder {
  id                  String   @id
  tenantId            String   @map("tenant_id")
  customerId          String?  @map("customer_id")
  customerUserId      String?  @map("customer_user_id")
  shopifyOrderId      String?  @map("shopify_order_id")
  shopifyOrderNumber  String?  @map("shopify_order_number")
  shopifyCustomerId   String?  @map("shopify_customer_id")
  source              String   @default("shopify")
  idempotencyKey      String?  @map("idempotency_key")
  email               String?
  phone               String?
  subtotal            Decimal  @default(0) @db.Decimal(12, 2)
  totalDiscounts      Decimal  @default(0) @map("total_discounts") @db.Decimal(12, 2)
  totalTax            Decimal  @default(0) @map("total_tax") @db.Decimal(12, 2)
  totalPrice          Decimal  @default(0) @map("total_price") @db.Decimal(12, 2)
  totalShipping       Decimal  @default(0) @map("total_shipping") @db.Decimal(12, 2)
  totalRefunded       Decimal  @default(0) @map("total_refunded") @db.Decimal(12, 2)
  currency            String   @default("USD")
  financialStatus     String?  @map("financial_status")
  fulfillmentStatus   String?  @map("fulfillment_status")
  fulfillmentMode     String   @default("unknown") @map("fulfillment_mode")
  notes               String?
  tags                String[] @default([])
  riskLevel           String?  @map("risk_level")
  lineItems           Json     @default("[]") @map("line_items")
  shippingAddress     Json?    @map("shipping_address")
  billingAddress      Json?    @map("billing_address")
  discountCodes       Json?    @map("discount_codes")
  fulfillments        Json?    @map("fulfillments")
  refunds             Json?    @map("refunds")
  designFiles         Json     @default("[]") @map("design_files")
  fulfillmentEvidence Json?    @map("fulfillment_evidence")
  rawData             Json?    @map("raw_data")
  processedAt         DateTime? @map("processed_at")
  cancelledAt         DateTime? @map("cancelled_at")
  closedAt            DateTime? @map("closed_at")
  syncedAt            DateTime @default(now()) @map("synced_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerUser CustomerUser?          @relation(fields: [customerUserId], references: [id], onDelete: SetNull)
  pickupOrder  CommercePickupOrder?

  @@unique([tenantId, shopifyOrderId])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, customerId])
  @@index([tenantId, customerUserId])
  @@index([tenantId, shopifyCustomerId])
  @@index([tenantId, processedAt])
  @@index([tenantId, fulfillmentMode])
  @@map("commerce_orders")
}

model CommercePickupOrder {
  id              String   @id
  tenantId        String   @map("tenant_id")
  orderId         String   @unique @map("order_id")
  customerId      String?  @map("customer_id")
  customerUserId  String?  @map("customer_user_id")
  status          String   @default("pending")
  qrCode          String?  @map("qr_code")
  orderNumber     String?  @map("order_number")
  customerName    String?  @map("customer_name")
  customerEmail   String?  @map("customer_email")
  pickupAt        DateTime? @map("pickup_at")
  designFiles     Json     @default("[]") @map("design_files")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order        CommerceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerUser CustomerUser? @relation(fields: [customerUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, qrCode])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("commerce_pickup_orders")
}

model CommerceActivityLog {
  id                String   @id
  tenantId          String   @map("tenant_id")
  customerId        String?  @map("customer_id")
  shopifyCustomerId String?  @map("shopify_customer_id")
  eventType         String   @map("event_type")
  productId         String?  @map("product_id")
  variantId         String?  @map("variant_id")
  shopifyProductId  String?  @map("shopify_product_id")
  shopifyVariantId  String?  @map("shopify_variant_id")
  payload           Json     @default("{}")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  referrer          String?
  createdAt         DateTime @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId, customerId, createdAt])
  @@index([tenantId, shopifyCustomerId, createdAt])
  @@index([tenantId, eventType, createdAt])
  @@map("commerce_activity_logs")
}

model CustomerInsight {
  id                    String   @id
  tenantId              String   @map("tenant_id")
  customerId            String   @unique @map("customer_id")
  clvScore              Int      @default(0) @map("clv_score")
